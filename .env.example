# Signing credentials for `npm run package` — read from this repo-root .env.
# Generate once at: https://addons.mozilla.org/developers/addon/api/key/
# Copy this file to `.env` (gitignored) and fill in your values.
WEB_EXT_API_KEY=your-jwt-issuer
WEB_EXT_API_SECRET=your-jwt-secret

# Note: your Gemini API key and Google OAuth credentials are NOT set here —
# you enter those in the extension's Settings page at runtime.
