{
  "name": "job-tailor-extension",
  "version": "0.1.1",
  "description": "AI cover letters from your real experience — Firefox extension",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "sign": "dotenv -- web-ext sign --source-dir=dist --channel=unlisted",
    "package": "npm run build && npm run sign"
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/google-genai": "^0.2.0",
    "langchain": "^0.3.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.14",
    "vite-plugin-web-extension": "^4.4.3",
    "web-ext": "^8.3.0"
  }
}